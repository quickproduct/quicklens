# ============================================================================
# QuickLens - Environment Configuration
# ============================================================================
# Copy to .env and update values. Defaults optimized for local development.

# ── General ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CONTAINER_PREFIX=ql
DEBUG=true
LOG_LEVEL=DEBUG

# ── Security ────────────────────────────────────────────────────────────────
# Generate for production: openssl rand -hex 32
JWT_SECRET_KEY=quicklens-dev-secret-change-me-in-production
JWT_ALGORITHM=HS256

# ── Initial Admin ───────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@quicklens.local
DEFAULT_ADMIN_PASSWORD=admin
ALLOW_REGISTRATION=true

# ── Network ─────────────────────────────────────────────────────────────────
EXTERNAL_PORT=80

# ── Ollama Integration ──────────────────────────────────────────────────────
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_POLL_INTERVAL=30

# ── Cloud Provider API Keys (optional) ──────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=

# ── Data ────────────────────────────────────────────────────────────────────
SEED_DEMO_DATA=false
DATA_RETENTION_DAYS=30

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_DIR=/app/logs
